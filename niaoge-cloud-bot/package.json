{
  "name": "niaoge-cloud-bot",
  "version": "1.0.0",
  "description": "鸟哥之王云端挂机 - 浏览器关闭后WebSocket保持连接的自动化任务服务",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs niaoge-cloud-bot"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^4.21.0",
    "express-fileupload": "^1.5.0",
    "lz4js": "^0.2.0",
    "node-cron": "^3.0.3",
    "sql.js": "^1.10.0",
    "ws": "^8.18.0",
    "xxtea-node": "^1.1.5"
  }
}
